    "react-dom": "^19.2.4",
    "typescript": "^6.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lox-space/lox",
    "directory": "packages/lox-space-react"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@lox-space/wasm": "workspace:^"
  },
  "peerDependencies": {
    "leva": "^0.10.0"
  }
