//
// SPDX-License-Identifier: MPL-2.0

import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
---

<Layout title="Kerolox - Lox Space Demos">
  <main>
    <h1>Kerolox</h1>
    <p class="subtitle">Interactive demos for the <a href="https://github.com/lox-space/lox">Lox</a> astrodynamics toolkit</p>

    <h2>Keplerian Orbit</h2>
    <ul role="list" class="card-grid">
      <Card
        href="/svelte/keplerian"
        title="Svelte + Threlte"
        body="3D Keplerian orbit visualization using Svelte 5 and Threlte."
      />
    </ul>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding: 2rem 1rem;
    width: 800px;
    max-width: calc(100% - 2rem);
    color: white;
    font-size: 18px;
    line-height: 1.6;
  }
  h1 {
    font-size: 3rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 0.25em;
  }
  h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .subtitle {
    text-align: center;
    color: #999;
    margin-bottom: 2rem;
  }
  .subtitle a {
    color: #7c8aff;
    text-decoration: none;
  }
  .subtitle a:hover {
    text-decoration: underline;
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(24ch, 1fr));
    gap: 1.5rem;
    padding: 0;
  }
</style>
